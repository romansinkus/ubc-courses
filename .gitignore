# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnp.js
.yarn/install-state.gz

# testing
/coverage
.nyc_output

# next.js
/.next/
/out/
/build
/dist
.swc

# production / deploy
.vercel

# environment & secrets
.env*
!.env.example

# typescript
*.tsbuildinfo
next-env.d.ts

# debug & logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# caches
.cache
.eslintcache
.turbo

# misc
.DS_Store
*.pem
Thumbs.db
*.swp
*.swo
*~

# IDEs & editors
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# AI assistant local settings (not shared project rules)
.claude/

# Supabase CLI (if added later)
supabase/.branches
supabase/.temp
