# Public — safe for the browser. Get from your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only — used by Drizzle migrations and the seed script.
# Get from Supabase: Settings → Database → "Connection string" → URI (use the pooler URL).
DATABASE_URL=postgres://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
